{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paged.media/schemas/plugin-manifest.schema.json",
  "title": "Paged plugin manifest",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "apiVersion"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z][a-z0-9-]*)+$",
      "description": "Reverse-DNS plugin identity; namespace prefix for all contribution ids."
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[0-9A-Za-z.-]+)?$"
    },
    "apiVersion": {
      "type": "string",
      "minLength": 1
    },
    "publisher": {
      "type": "string"
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "document": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "read": {
              "enum": [
                "broad",
                "scoped"
              ]
            },
            "write": {
              "enum": [
                "broad",
                "scoped"
              ]
            }
          }
        },
        "rendering": {
          "type": "array",
          "items": {
            "enum": [
              "sceneLayer",
              "overlay",
              "hitTest",
              "resourceProvider"
            ]
          }
        },
        "keybindings": {
          "type": "boolean",
          "description": "The bundle registers keybindings directly via contribute.keybinding. Keybindings have no id to list under contributes, so this boolean is their capability declaration."
        },
        "editContext": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "assets": {
          "type": "array",
          "description": "Asset-store reads the bundle uses. \"fonts\" gates host.assets.getFontFace (W-06); \"images\" gates host.assets.getPlacedImage (C-5 / I-04, core v42). See DESIGN.md §13.",
          "items": {
            "enum": [
              "fonts",
              "images"
            ]
          }
        },
        "network": {
          "description": "Network reach the bundle declares (D-03). Boolean shorthand, or a per-origin allow-list + purpose. Reach is always consent-gated; documents do not fetch on open.",
          "oneOf": [
            { "type": "boolean" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["origins"],
              "properties": {
                "origins": {
                  "oneOf": [
                    {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "pattern": "^https?://[^/]+$"
                      }
                    },
                    { "const": "consent" }
                  ]
                },
                "purpose": { "type": "string" }
              }
            }
          ]
        },
        "dataProviders": {
          "type": "object",
          "description": "Data-provider roles (paged.data §7.1 / D-09). 'publish' = categories the bundle may register providers in; 'consume' = categories it may discover + read. The neutral cross-plugin composition; plugins rendezvous at host.dataProviders, never by direct contact.",
          "additionalProperties": false,
          "properties": {
            "publish": { "type": "array", "items": { "type": "string" } },
            "consume": { "type": "array", "items": { "type": "string" } }
          }
        },
        "storage": {
          "type": "object",
          "description": "Persistent binary storage (K-4 / S-08). 'blob' gates the OPFS-backed host.blob byte store; 'quotaBytes' requests a ceiling (host enforces the stricter of it and its hard per-plugin cap).",
          "additionalProperties": false,
          "properties": {
            "blob": { "type": "boolean" },
            "quotaBytes": { "type": "integer" }
          }
        },
        "clipboard": {
          "enum": [
            "none",
            "vector",
            "full"
          ]
        },
        "workers": {
          "type": "object",
          "description": "Worker spawn + SharedArrayBuffer (K-3 / S-07 / I-02). 'max' is the worker-count ceiling requested (host clamps to min(declared, hardwareConcurrency, 8)); 'sharedMemory' declares SAB use (gates allocateShared); 'maxSharedBytes' requests a per-bundle shared-memory ceiling (host enforces the stricter of it and its 256 MiB default cap). Gates host.workers.",
          "additionalProperties": false,
          "required": [
            "max"
          ],
          "properties": {
            "max": {
              "type": "integer",
              "minimum": 1,
              "maximum": 8
            },
            "sharedMemory": {
              "type": "boolean"
            },
            "maxSharedBytes": {
              "type": "integer",
              "minimum": 1,
              "maximum": 268435456
            }
          }
        },
        "secrets": {
          "type": "object",
          "description": "Host credential-store door (D-11; rfc-credential-store). 'sources' grants host.secrets for authenticated DB-attach / remote sources. REFERENCE-ONLY + host-owned: plugins hold credentialRef strings, never secret material; the surface has set/exists/forget and NO get. Gates host.secrets.",
          "additionalProperties": false,
          "required": [
            "sources"
          ],
          "properties": {
            "sources": {
              "type": "boolean"
            }
          }
        },
        "wasm": {
          "type": "array",
          "description": "Declared WebAssembly artifacts the bundle ships and loads at runtime (capability-gated, declared-only, budgeted). See docs/wasm-packaging.md.",
          "items": {
            "type": "object",
            "required": [
              "name",
              "path",
              "purpose"
            ],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "path": {
                "type": "string",
                "pattern": "^(?!/)(?!.*\\.\\.).+\\.wasm$",
                "description": "Bundle-relative path to the .wasm file; no leading slash, no '..' segment."
              },
              "purpose": {
                "enum": [
                  "layout",
                  "codec",
                  "compute",
                  "engine"
                ]
              },
              "maxBytes": {
                "type": "integer",
                "minimum": 1,
                "maximum": 67108864,
                "description": "Per-artifact byte ceiling (tightens, never widens, the host cap). Host cap: 8 MiB for layout/codec/compute, 64 MiB for purpose:\"engine\" (D-07b — vendored DB engines like DuckDB-WASM)."
              }
            }
          }
        }
      }
    },
    "contributes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tools": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "panels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "commands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "editContexts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "type",
              "entry"
            ],
            "additionalProperties": false,
            "properties": {
              "type": {
                "type": "string"
              },
              "entry": {
                "enum": [
                  "doubleClick",
                  "command"
                ]
              },
              "priority": {
                "type": "integer"
              }
            }
          }
        },
        "objectTypes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "type",
              "bakedFallback"
            ],
            "additionalProperties": false,
            "properties": {
              "type": {
                "type": "string"
              },
              "bakedFallback": {
                "enum": [
                  "group",
                  "rectangle",
                  "raster"
                ]
              }
            }
          }
        },
        "importers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exporters": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}